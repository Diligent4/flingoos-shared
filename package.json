{
  "name": "@flingoos/shared",
  "version": "0.2.0",
  "description": "Shared types, schemas, validation, and storage access for Flingoos services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./schemas": "./dist/schemas.js",
    "./validation": "./dist/validation.js",
    "./usage-logging": "./dist/usage-logging/index.js",
    "./priority-integration": "./dist/priority-integration.js",
    "./security": "./dist/security.js",
    "./storage": "./dist/storage/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:schemas": "npm run build && node scripts/generate-schemas.js",
    "validate": "npm run build && node dist/validation.js",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:usage-logging": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=usage-logging",
    "test:all": "npm run test && npm run build:schemas",
    "clean": "rm -rf dist python"
  },
  "devDependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "google-auth-library": "^10.6.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "peerDependencies": {
    "@google-cloud/storage": ">=7.14.0",
    "google-auth-library": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/storage": {
      "optional": true
    },
    "google-auth-library": {
      "optional": true
    }
  },
  "keywords": [
    "types",
    "schemas",
    "validation",
    "storage",
    "flingoos"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar": "^7.5.8",
    "glob": "^10.5.0",
    "minimatch": "^10.2.1"
  }
}
