{
  "name": "@flingoos/shared",
  "version": "2.2.0",
  "description": "Shared types, schemas, validation, and storage access for Flingoos services",
  "repository": {
    "type": "git",
    "url": "https://github.com/Diligent4/flingoos-shared.git"
  },
  "publishConfig": {
    "registry": "https://me-west1-npm.pkg.dev/flingoos-production/flingoos-npm/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "default": "./dist/validation.js"
    },
    "./usage-logging": {
      "types": "./dist/usage-logging/index.d.ts",
      "default": "./dist/usage-logging/index.js"
    },
    "./priority-integration": {
      "types": "./dist/priority-integration.d.ts",
      "default": "./dist/priority-integration.js"
    },
    "./shopify-integration": {
      "types": "./dist/shopify-integration.d.ts",
      "default": "./dist/shopify-integration.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "default": "./dist/security.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "default": "./dist/storage/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:schemas": "npm run build && node scripts/generate-schemas.js",
    "validate": "npm run build && node dist/validation.js",
    "test": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:usage-logging": "npm run build && node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=usage-logging",
    "test:all": "npm run test && npm run build:schemas",
    "clean": "rm -rf dist python"
  },
  "devDependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "google-auth-library": "^9.15.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "peerDependencies": {
    "@google-cloud/storage": ">=7.14.0",
    "google-auth-library": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@google-cloud/storage": {
      "optional": true
    },
    "google-auth-library": {
      "optional": true
    }
  },
  "keywords": [
    "types",
    "schemas",
    "validation",
    "storage",
    "flingoos"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar": "^7.5.13",
    "glob": "^11.0.0",
    "minimatch": "^10.2.4"
  }
}
